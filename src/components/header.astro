<div id="passwordModal" class="auth-modal" style="display: none;">
    <div class="auth-modal-content">
        <h3>管理員身分驗證</h3>
        <div class="auth-form-group">
            <input type="password" id="adminPwd" placeholder="請輸入通行密碼" />
        </div>
        <div class="auth-btn-group">
            <button id="closePasswordModalBtn" class="auth-btn auth-btn-cancel">取消</button>
            <button id="verifyPasswordBtn" class="auth-btn auth-btn-submit">驗證</button>
        </div>
    </div>
</div>

<style>
    /* ==========================================================================
       頁首基本設定與密碼彈窗樣式
       ========================================================================== */
    .header-navbar {
        width: 100%;
        background-color: #ffffff;
        border-bottom: 1px solid #EAEAEA;
        position: relative;
        z-index: 9000;
    }
    .header-navbar-container {
        max-width: 1600px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0px 50px;
    }
    .header-logo-area {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 10px 0px;
    }
    .header-logo-icon img { max-height: 50px; width: auto; }
    .header-logo-link:hover { cursor: pointer; opacity: 0.8; transition: opacity 0.2s; }

    /* 管理員登入按鈕 */
    .admin-icon-btn {
        background: none; border: none; cursor: pointer; padding: 5px;
        display: flex; align-items: center; transition: transform 0.1s;
    }
    .admin-icon-btn:hover { transform: scale(1.05); }
    #auth-btn #auth-btn-img { width: 40px; height: auto; opacity: 0.5; transition: all 0.3s; }
    
    /* 登入成功後的發光發亮狀態 */
    #auth-btn.logged-in #auth-btn-img {
        opacity: 1;
        filter: drop-shadow(0 0 6px rgba(20, 101, 163, 0.8));
    }

    .search-icon-btn { background: none; border: none; font-size: 1.35rem; cursor: pointer; padding: 5px; color: #333333; display: flex; align-items: center; }
    .search-icon-btn:hover { color: #1465A3; }
    .header-nav-links { display: flex; align-items: center; gap: 35px; }
    .header-nav-links a { text-decoration: none; color: #333333; font-size: 1rem; font-weight: 500; transition: color 0.2s; }
    .header-nav-links a:hover { color: #1465A3; }
    .menu-toggle { display: none; background: none; border: none; font-size: 2rem; padding: 5px 10px;}
    .more-dropdown { position: relative; display: inline-block; }
    .more-toggle { cursor: pointer; font-weight: bold; }
    .more-dropdown-content {
        display: none; position: absolute; right: 0; top: 100%; background-color: #ffffff;
        min-width: 150px; box-shadow: 0px 8px 16px rgba(0,0,0,0.15); border-radius: 6px; z-index: 9999; padding: 5px 0;
    }
    .more-dropdown:hover .more-dropdown-content { display: block; }
    .more-dropdown-content :global(a) { color: #333333 !important; padding: 12px 16px !important; text-decoration: none !important; display: block !important; text-align: left !important; }
    .more-dropdown-content :global(a:hover) { background-color: #f5f5f5 !important; color: #1465A3 !important; }

    /* 🔐 密碼彈窗專屬 CSS */
    .auth-modal {
        position: fixed; top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0,0,0,0.6); z-index: 30000; display: flex; justify-content: center; align-items: center;
    }
    .auth-modal-content {
        background: white; padding: 30px; border-radius: 8px; width: 320px; text-align: center;
        box-shadow: 0 4px 20px rgba(0,0,0,0.3); font-family: sans-serif;
    }
    .auth-modal-content h3 { margin: 0 0 20px 0; color: #4a3728; font-size: 18px; }
    .auth-form-group input { width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; font-size: 14px; text-align: center; }
    .auth-btn-group { display: flex; justify-content: space-between; margin-top: 20px; gap: 10px; }
    .auth-btn { flex: 1; padding: 10px; border: none; border-radius: 4px; cursor: pointer; font-size: 14px; }
    .auth-btn-cancel { background: #eee; color: #333; }
    .auth-btn-submit { background: #1465A3; color: white; }

    @media (max-width: 768px) {
        .header-navbar-container { padding: 10px 10px; }
        .header-logo-area { width: 100%; display: flex; justify-content: flex-start; align-items: center; }
        .menu-toggle { 
            display: block !important; font-size: 2rem !important; color: #333333 !important; background: #ffffff !important; 
            padding: 5px 10px !important; border-radius: 6px !important; border: none !important; cursor: pointer !important; margin-left: auto;
        }
        .header-nav-links {
            display: none; flex-direction: column; position: absolute; top: 100%; left: 0; width: 100%;
            background: #fff; padding: 20px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); text-align: center; z-index: 9999; gap: 20px;
        }
        .menu-toggle:hover { color: #1465A3; }
        .header-nav-links.active { display: flex; }
        .search-icon-btn { justify-content: center; width: 100%; font-size: 1.5rem; padding: 10px 0; }
    }
</style>

<script>
    // 初始化 Supabase 客戶端 (與頁面共用全域變數)
    const supabaseUrl = 'https://blqlrxqckiuvgevmakbu.supabase.co';
    const supabaseKey = 'sb_publishable_qFXwpuGChVdRwjc9K7prVQ_PgYmlnpG';
    // 防止重複宣告
    window.client = window.client || (window.supabase ? window.supabase.createClient(supabaseUrl, supabaseKey) : null);

    const setupHeaderAuth = () => {
        const authBtn = document.getElementById('auth-btn');
        const passwordModal = document.getElementById('passwordModal');
        const closePasswordModalBtn = document.getElementById('closePasswordModalBtn');
        const verifyPasswordBtn = document.getElementById('verifyPasswordBtn');
        const adminPwdInput = document.getElementById('adminPwd') as HTMLInputElement | null;
        const body = document.body;

        if (!authBtn || !passwordModal || !window.client) return;

        // 檢查並同步全域登入狀態
        const checkGlobalLoginState = async () => {
            const { data: { session } } = await window.client.auth.getSession();
            const addBlock = document.getElementById('clubGlobalAddBlock');
            
            if (session) {
                authBtn.classList.add('logged-in');
                body.classList.add('admin-mode-active');
                if (addBlock) addBlock.style.display = 'flex';
                authBtn.title = "管理員已登入 (點擊登出)";
            } else {
                authBtn.classList.remove('logged-in');
                body.classList.remove('admin-mode-active');
                if (addBlock) addBlock.style.display = 'none';
                authBtn.title = "管理員登入";
            }
        };

        // 按鈕點擊事件：未登入時開彈窗，已登入時點擊則登出
        authBtn.addEventListener('click', async () => {
            const { data: { session } } = await window.client.auth.getSession();
            if (session) {
                if (confirm("確定要登出管理員模式嗎？")) {
                    await window.client.auth.signOut();
                    alert("🔒 已安全登出管理員模式");
                    checkGlobalLoginState();
                    window.location.reload();
                }
            } else {
                passwordModal.style.display = 'flex';
                if (adminPwdInput) adminPwdInput.focus();
            }
        });

        // 關閉視窗
        const closeModal = () => {
            passwordModal.style.display = 'none';
            if (adminPwdInput) adminPwdInput.value = '';
        };
        if (closePasswordModalBtn) closePasswordModalBtn.onclick = closeModal;

        // 驗證密碼
        const verifyAdminPassword = async () => {
            if (!adminPwdInput) return;
            const pwd = adminPwdInput.value.trim();
            if (!pwd) return;

            const formattedEmail = `${pwd}@studio.local`;
            const { error } = await window.client.auth.signInWithPassword({ email: formattedEmail, password: pwd });
            
            if (error) {
                alert("❌ 通行密碼錯誤，拒絕存取。");
            } else {
                closeModal();
                alert("🔓 驗證成功！已開啟管理員權限。");
                await checkGlobalLoginState();
                window.location.reload(); // 重新整理讓頁面上的功能與 Badge 同步顯示
            }
        };

        if (verifyPasswordBtn) verifyPasswordBtn.onclick = verifyAdminPassword;
        if (adminPwdInput) {
            adminPwdInput.onkeydown = (e) => { if (e.key === 'Enter') verifyAdminPassword(); };
        }

        // 初次加載檢查狀態
        checkGlobalLoginState();
    };

    // 🟢 智慧收納與選單控制邏輯
    const setupHeaderMenu = () => {
        const toggleButton = document.querySelector('.menu-toggle') as HTMLButtonElement | null;
        const navLinks = document.querySelector('.header-nav-links') as HTMLElement | null;

        if (toggleButton && navLinks) {
            toggleButton.onclick = function(e) {
                navLinks.classList.toggle('active');
                e.stopPropagation();
            };
            document.addEventListener('click', function(e) {
                const target = e.target as HTMLElement;
                if (navLinks.classList.contains('active') && !navLinks.contains(target) && target !== toggleButton) {
                    navLinks.classList.remove('active');
                }
            });
        }

        const mainNav = document.querySelector('.header-nav-links') as HTMLElement | null;
        if (!mainNav) return;

        let moreMenu = document.getElementById('more-menu') as HTMLElement | null;
        let overflowLinks = document.getElementById('overflow-links') as HTMLElement | null;
        const searchBtn = document.getElementById('global-search-btn');
        const allLinks = Array.from(mainNav.children).filter(el => el !== moreMenu && el !== searchBtn && el.tagName === 'A') as HTMLElement[];

        const adjustNavItems = () => {
            if (!mainNav || !moreMenu || !overflowLinks) return;
            if (window.innerWidth <= 768) {
                allLinks.forEach(item => mainNav.insertBefore(item, moreMenu));
                moreMenu.style.display = 'none';
                return;
            }

            moreMenu.style.display = 'none'; 
            overflowLinks.innerHTML = '';    
            allLinks.forEach(item => mainNav.insertBefore(item, moreMenu)); 

            let navContainerWidth = mainNav.offsetWidth;
            let totalWidth = 0;
            const moreBtnWidth = 90; 

            for (let i = 0; i < allLinks.length; i++) {
                const item = allLinks[i];
                const itemStyle = window.getComputedStyle(item);
                const marginLeft = parseFloat(itemStyle.marginLeft) || 0;
                const marginRight = parseFloat(itemStyle.marginRight) || 0;
                totalWidth += item.offsetWidth + marginLeft + marginRight;

                if (totalWidth + moreBtnWidth > navContainerWidth) {
                    moreMenu.style.display = 'inline-block'; 
                    const remainingLinks = allLinks.slice(i);
                    remainingLinks.forEach(link => overflowLinks!.appendChild(link));
                    break; 
                }
            }
        };

        adjustNavItems();
        let resizeTimeout: number;
        window.addEventListener('resize', () => {
            clearTimeout(resizeTimeout);
            resizeTimeout = window.setTimeout(adjustNavItems, 100);
        });

        if (searchBtn) {
            searchBtn.onclick = () => console.log("觸發全域搜尋");
        }
    };

    // 執行初始化
    setupHeaderAuth();
    setupHeaderMenu();
</script>