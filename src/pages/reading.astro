---
// =========================================================================
// 1. Astro 圍欄區：這裡的程式碼只在「GitHub Actions 打包時」執行 (SEO 核心)
// =========================================================================
import BaseLayout from '../layouts/Baselayout.astro';

const supabaseUrl = 'https://blqlrxqckiuvgevmakbu.supabase.co';
const supabaseKey = 'sb_publishable_qFXwpuGChVdRwjc9K7prVQ_PgYmlnpG';
const tableName = 'reading_clubs';

// 在打包時，用原生最輕量安全的 fetch 取得最新資料並生成 HTML
const response = await fetch(`${supabaseUrl}/rest/v1/${tableName}?select=*&order=sort_order.desc`, {
  headers: {
    'apikey': supabaseKey,
    'Authorization': `Bearer ${supabaseKey}`
  }
});

let clubsData = [];
if (response.ok) {
  clubsData = await response.json();
} else {
  console.error("Astro 預編譯撈取 Supabase 資料失敗");
}
---

<BaseLayout> 

  <main class="main-container">
    
    <div class="header-area" id="mainHeaderArea">
      <div class="banner">
        <img src="/images/reading_clubs.jpg" alt="讀書會活動橫幅" oncontextmenu="return false;" ondragstart="return false;">
      </div>
      <button class="logo-btn" id="adminSecretBtn" title="管理員密道">
        <img src="/images/logo-small2.png" alt="Slow Pace Studio Logo" oncontextmenu="return false;" ondragstart="return false;">
      </button>
    </div>

    <div class="club-global-add-wrap" id="clubGlobalAddBlock">
      <button class="btn-global-add" id="openCreateModalBtn">
        <span>新增讀書會項目</span>
      </button>
    </div>

<div class="grid-container" id="clubs-container">
  {clubsData.map((item, index) => {
    // 處理內文字串換行
    const formattedContent = item.content ? item.content.replace(/\n/g, '<br>') : '';
    return (
      /* 🌟 修正點：把網址的 ${item.id} 改成 ${encodeURIComponent(item.title)} */
      <a href={`/day/clubs/${encodeURIComponent(item.title || '未命名')}/`} class="card-link" style="text-decoration: none; color: inherit;">
        <section class="card" data-index={index}>
          {/* 🌟 編輯按鈕加上 stopPropagation 避免觸發點擊跳轉 */}
          <div class="edit-badge" data-edit-index={index} onclick="event.preventDefault(); event.stopPropagation();">編輯 ✎</div>
          <h2>{item.title || '未命名'}</h2>
          <hr />
          <img class="card-img" src={item.image_url || ''} alt={item.title} oncontextmenu="return false;" ondragstart="return false;" />
          <div class="content-text" set:html={formattedContent}></div>
        </section>
      </a>
    );
  })}
</div>
  </main>

  <div class="alert-modal" id="customAlert">
    <div class="alert-content">
      <p id="alertMessage">提示訊息</p>
      <button class="btn btn-submit" style="margin:0; width:100%;" id="closeAlertBtn">確定</button>
    </div>
  </div>

  <div class="admin-modal" id="passwordModal">
    <div class="admin-content" style="max-width: 350px;">
      <h3>管理員驗證</h3>
      <div class="form-group">
        <label for="adminPwd">請輸入通行密碼：</label>
        <input type="password" id="adminPwd" placeholder="請輸入密碼">
      </div>
      <div class="btn-group">
        <button type="button" class="btn" id="closePasswordModalBtn">取消</button>
        <button type="button" class="btn btn-submit" id="verifyPasswordBtn">確認</button>
      </div>
    </div>
  </div>

  <div class="admin-modal" id="adminModal">
    <div class="admin-content">
      <h3 id="modalTitle">新增讀書會資料</h3>
      <form id="clubForm">
        <input type="hidden" id="editingId">
        
        <div class="form-group">
          <label>單元名稱 (title)</label>
          <input type="text" id="clubTitle" required placeholder="例如：象是笨蛋">
        </div>
        
        <div class="form-group">
          <label>顯示排序權重 (sort_order)</label>
          <input type="number" id="clubSortOrder" required value="10" placeholder="數字越小越後面，1會落在最右下角">
        </div>
        
        <div class="form-group">
          <label>圖片來源</label>
          <div class="radio-group">
            <label><input type="radio" name="imgSource" value="upload" checked id="radioSrcUpload"> 上傳新相片</label>
            <label><input type="radio" name="imgSource" value="url" id="radioSrcUrl"> 手動輸入位置/GitHub路徑</label>
          </div>
          <div id="uploadInputSection">
            <input type="file" id="clubImageFile" accept="image/*">
          </div>
          <div id="urlInputSection" style="display: none;">
            <input type="text" id="clubImageUrlInput" placeholder="可填寫外部網址或 GitHub 的相片路徑，例如: images/book1.jpg">
          </div>
        </div>

        <div class="form-group">
          <label>內容介紹 (content)</label>
          <textarea id="clubContent" rows="8" required placeholder="請輸入介紹內文..."></textarea>
        </div>
        
        <div class="btn-group">
          <button type="button" class="btn" id="closeAdminModalBtn">取消</button>
          <button type="submit" id="submitBtn" class="btn btn-submit">儲存資料</button>
        </div>
      </form>
    </div>
  </div>


</Baselayout>

<script is:inline src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script>
  window.supabaseUrl = 'https://blqlrxqckiuvgevmakbu.supabase.co';
  window.supabaseKey = 'sb_publishable_qFXwpuGChVdRwjc9K7prVQ_PgYmlnpG';
  window.TABLE_NAME = 'reading_clubs'; 
  window.STORAGE_BUCKET_NAME = 'reading_clubs'; 
  window.client = supabase.createClient(window.supabaseUrl, window.supabaseKey);

  let globalClubsData = []; 

  document.addEventListener("DOMContentLoaded", async () => {
    const { data } = await window.client.from(window.TABLE_NAME).select('*').order('sort_order', { ascending: false });
    globalClubsData = data || [];

    loadExternalHeader();
    loadExternalFooter();
    bindDOMEvents();
    checkLoginState();
  });

  function bindDOMEvents() {
    document.querySelectorAll('.edit-badge').forEach(badge => {
      badge.addEventListener('click', (e) => {
        const index = parseInt(badge.getAttribute('data-edit-index'), 10);
        setupEditForm(index, e);
      });
    });

    document.getElementById('adminSecretBtn').onclick = openPasswordModal;
    document.getElementById('closePasswordModalBtn').onclick = closePasswordModal;
    document.getElementById('verifyPasswordBtn').onclick = verifyPassword;
    document.getElementById('openCreateModalBtn').onclick = openCreateModal;
    document.getElementById('closeAdminModalBtn').onclick = closeAdminModal;
    document.getElementById('closeAlertBtn').onclick = closeCustomAlert;
    document.getElementById('clubForm').onsubmit = handleSubmit;

    document.getElementById('radioSrcUpload').onclick = () => switchImgMethod('upload');
    document.getElementById('radioSrcUrl').onclick = () => switchImgMethod('url');
  }

  function showAlert(msg) {
    document.getElementById('alertMessage').innerText = msg;
    document.getElementById('customAlert').style.display = 'flex';
  }
  function closeCustomAlert() {
    document.getElementById('customAlert').style.display = 'none';
  }
  function openPasswordModal() {
    document.getElementById('passwordModal').style.display = 'flex';
    document.getElementById('adminPwd').focus();
  }
  function closePasswordModal() {
    document.getElementById('passwordModal').style.display = 'none';
    document.getElementById('adminPwd').value = '';
  }

  async function verifyPassword() {
    const pwd = document.getElementById('adminPwd').value.trim();
    if (!pwd) return;
    const formattedEmail = `${pwd}@studio.local`;
    const { error } = await window.client.auth.signInWithPassword({ email: formattedEmail, password: pwd });
    
    if (error) {
      showAlert("❌ 通行密碼錯誤，拒絕存取。");
    } else {
      closePasswordModal();
      showAlert("🔓 驗證成功！已開啟管理員權限。");
      checkLoginState();
    }
  }

  async function checkLoginState() {
    const { data: { session } } = await window.client.auth.getSession();
    const addBlock = document.getElementById('clubGlobalAddBlock');
    if (session) {
      document.body.classList.add('admin-mode-active');
      if (addBlock) addBlock.style.display = 'flex';
    } else {
      document.body.classList.remove('admin-mode-active');
      if (addBlock) addBlock.style.display = 'none';
    }
  }

  async function loadExternalHeader() {
    try {
      const resp = await fetch('/header.html');
      if (resp.ok) document.getElementById('header-container').innerHTML = await resp.text();
    } catch (e) {}
  }
  async function loadExternalFooter() {
    try {
      const resp = await fetch('/footer.html');
      if (resp.ok) document.getElementById('global-footer').innerHTML = await resp.text();
    } catch (e) {}
  }

  function openCreateModal() {
    document.getElementById('modalTitle').innerText = "新增讀書會資料";
    document.getElementById('editingId').value = '';
    document.getElementById('clubForm').reset();
    switchImgMethod('upload');
    document.getElementById('adminModal').style.display = 'flex';
  }

  function setupEditForm(index, event) {
    event.stopPropagation();
    const item = globalClubsData[index];
    if (!item) return;

    document.getElementById('modalTitle').innerText = "修改讀書會資料";
    document.getElementById('editingId').value = item.id;
    document.getElementById('clubTitle').value = item.title || '';
    document.getElementById('clubSortOrder').value = item.sort_order || 10;
    document.getElementById('clubContent').value = item.content || '';
    
    switchImgMethod('url');
    document.getElementById('radioSrcUrl').checked = true;
    document.getElementById('clubImageUrlInput').value = item.image_url || '';
    document.getElementById('adminModal').style.display = 'flex';
  }

  function closeAdminModal() {
    document.getElementById('adminModal').style.display = 'none';
    document.getElementById('clubForm').reset();
  }

  function switchImgMethod(method) {
    if (method === 'upload') {
      document.getElementById('uploadInputSection').style.display = 'block';
      document.getElementById('urlInputSection').style.display = 'none';
    } else {
      document.getElementById('uploadInputSection').style.display = 'none';
      document.getElementById('urlInputSection').style.display = 'block';
    }
  }

  function compressImage(file, maxWidth = 1200, quality = 0.8) {
    return new Promise((resolve) => {
      const reader = new FileReader();
      reader.readAsDataURL(file);
      reader.onload = (e) => {
        const img = new Image();
        img.src = e.target.result;
        img.onload = () => {
          let width = img.width, height = img.height;
          if (width > maxWidth) { height = Math.round((height * maxWidth) / width); width = maxWidth; }
          const canvas = document.createElement('canvas');
          canvas.width = width; canvas.height = height;
          canvas.getContext('2d').drawImage(img, 0, 0, width, height);
          canvas.toBlob((blob) => resolve(blob), file.type, quality);
        };
      };
    });
  }

  async function handleSubmit(event) {
    event.preventDefault();
    const submitBtn = document.getElementById('submitBtn');
    const editingId = document.getElementById('editingId').value;
    const title = document.getElementById('clubTitle').value;
    const sortOrder = parseInt(document.getElementById('clubSortOrder').value, 10);
    const content = document.getElementById('clubContent').value;
    const imgSource = document.querySelector('input[name="imgSource"]:checked').value;
    
    submitBtn.disabled = true;
    let imageUrl = '';

    try {
      if (imgSource === 'upload') {
        const fileInput = document.getElementById('clubImageFile');
        if (fileInput.files.length === 0 && !editingId) { 
          showAlert("請選取相片！"); submitBtn.disabled = false; return; 
        }
        if (fileInput.files.length > 0) {
          let uploadPayload = fileInput.files[0];
          if (uploadPayload.type.startsWith('image/')) {
            try { uploadPayload = await compressImage(uploadPayload); } catch (e) {}
          }
          const fileExt = fileInput.files[0].name.split('.').pop();
          const fileName = `${Date.now()}.${fileExt}`;
          const { error: storageError } = await window.client.storage.from(window.STORAGE_BUCKET_NAME).upload(fileName, uploadPayload);
          if (storageError) throw storageError;
          imageUrl = window.client.storage.from(window.STORAGE_BUCKET_NAME).getPublicUrl(fileName).data.publicUrl;
        }
      } else {
        imageUrl = document.getElementById('clubImageUrlInput').value.trim();
      }

      const payload = { title, content, sort_order: sortOrder };
      if (imageUrl) payload.image_url = imageUrl;

      let resError = editingId 
        ? (await window.client.from(window.TABLE_NAME).update(payload).eq('id', editingId)).error
        : (await window.client.from(window.TABLE_NAME).insert([payload])).error;

      if (resError) throw resError;

      // 🌟 核心修改：當 Supabase 儲存成功後，立刻直接由前端發送 API 給 GitHub Actions 觸發打包
      try {
        await fetch('https://api.github.com/repos/studioslowpace/day/dispatches', {
          method: 'POST',
          headers: {
            'Accept': 'application/vnd.github+json',
            // ⚠️ 請務必把下方的 ghp_ 開頭字串換成你自己的 GitHub Token 喔！
            'Authorization': 'Bearer ghp_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',
          },
          body: JSON.stringify({
            event_type: 'supabase_update' // 這邊要跟你的 deploy.yml 的 types 對上
          })
        });
        console.log("🚀 GitHub Actions 打包請求已發送！");
      } catch (githubErr) {
        // 如果 GitHub 呼叫失敗，我們用 console 紀錄就好，不干擾使用者正常的儲存流程
        console.error("呼叫 GitHub 失敗，但資料已成功寫入 Supabase：", githubErr);
      }

      showAlert("🎉 資料儲存成功！網頁已通知 GitHub 開始重新編譯，大約 1~2 分鐘後會更新線上畫面。");
      closeAdminModal();
      setTimeout(() => window.location.reload(), 1500);

    } catch (err) {
      showAlert("❌ 錯誤：" + err.message);
      submitBtn.disabled = false;
    }
  }
</script>

<style>
  *, *::before, *::after {
    box-sizing: border-box;
  }
  body {
    --scrollbar-width: 0px;
    -webkit-text-size-adjust: 100%;
    text-size-adjust: 100%;
    font-size: 10px;
    overflow-x: auto;
    overflow-y: scroll;
    background-color: #70b39b; 
  }
  .main-container {
    line-height: 1.8;
    color: #333;
    max-width: 1000px;
    margin: 0 auto;
    padding: 40px 20px;
  }
  .header-area {
    position: relative;
    max-width: 100%;
    margin-bottom: 40px;
    border-radius: 8px;
    overflow: hidden;
  }
  .banner img {
    width: 100%;
    height: auto;
    display: block;
  }
  .logo-btn {
    position: absolute;
    left: 15px;
    bottom: 12px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 10;
    transition: transform 0.2s;
  }
  .logo-btn:hover {
    transform: scale(1.05);
  }
  .logo-btn img {
    max-width: 70px;
    height: auto;
    display: block;
    opacity: 0.9;
  }
  .grid-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 40px;
  }
  /* 🌟 卡片外層加上 Link 包裹樣式調整 */
  .card-link {
    display: block;
    transition: all 0.3s ease;
  }
  .card {
    background: #fff;
    padding: 25px;
    border-radius: 8px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.15);
    display: flex;
    flex-direction: column;
    cursor: pointer;
    height: 100%;
    position: relative;
  }
  .card-link:hover .card {
    transform: translateY(-5px);
  }
  .card h2 {
    font-size: 22px;
    color: #4a3728;
    text-align: center;
    margin-top: 0;
    font-weight: bold;
    padding: 0 20px;
  }
  .card hr {
    border: 0;
    border-top: 1px solid #eee;
    margin: 15px 0;
  }
  .card-img {
    width: 100%;
    aspect-ratio: 108 / 135; 
    object-fit: cover;
    border-radius: 4px;
    margin-bottom: 20px;
  }
  .edit-badge {
    display: none;
    position: absolute;
    top: 15px; right: 15px;
    background: #c8963e;
    color: white;
    padding: 4px 10px;
    font-size: 12px;
    border-radius: 4px;
    z-index: 5;
  }
  body.admin-mode-active .edit-badge {
    display: block;
  }
  .card .content-text {
    font-size: 15px;
    color: #555;
    text-align: justify;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .alert-modal, .admin-modal {
    display: none;
    position: fixed;
    top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0,0,0,0.6);
    z-index: 20000;
    justify-content: center;
    align-items: center;
  }
  .alert-content {
    background: white; padding: 25px; border-radius: 8px; width: 300px; text-align: center; font-size: 14px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.3);
  }
  .alert-content p { margin: 0 0 20px 0; color: #333; font-weight: bold; line-height: 1.5; }

  .admin-content {
    background: white; padding: 30px; border-radius: 8px; width: 90%; max-width: 500px; font-size: 14px; max-height: 90vh; overflow-y: auto;
  }
  .admin-content h3 { margin-top: 0; font-size: 20px; }
  .form-group { margin-bottom: 15px; }
  .form-group label { display: block; margin-bottom: 5px; font-weight: bold; }
  .form-group input, .form-group textarea {
    width: 100%; padding: 8px; box-sizing: border-box; border: 1px solid #ccc; border-radius: 4px;
  }
  .radio-group { display: flex; gap: 15px; margin-bottom: 10px; }
  .radio-group label { display: inline; font-weight: normal; cursor: pointer; }
  .btn-group { text-align: right; margin-top: 20px; }
  .btn { padding: 8px 16px; border: none; border-radius: 4px; cursor: pointer; }
  .btn-submit { background: #2b3929; color: white; margin-left: 10px; }

  .club-global-add-wrap {
    display: none;
    justify-content: center;
    margin: 30px auto 10px;
    width: 100%;
    max-width: 1500px;
  }
  .btn-global-add {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background-color: #2b73ff;
    color: #ffffff;
    border: none;
    padding: 12px 24px;
    font-size: 15px;
    font-weight: 500;
    border-radius: 6px;
    cursor: pointer;
    box-shadow: 0 4px 12px rgba(43, 115, 255, 0.2);
    transition: all 0.2s ease;
  }
  .btn-global-add:hover {
    background-color: #1456db;
    transform: translateY(-1px);
    box-shadow: 0 6px 15px rgba(43, 115, 255, 0.3);
  }

  @media (max-width: 600px) {
    .logo-btn img {
      max-width: 30px;
    }
  }
</style>